{
  "name": "next-best-practice",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#api/client": {
      "mock": "./tests/mocks/api-client.mock.ts",
      "default": "./lib/api/client.ts"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
